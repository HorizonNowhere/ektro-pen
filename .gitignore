# ─────── 第三方依赖 (不 commit, 用户按 INSTALL.md 拉) ───────

# Weasel fork (5.3 MB + librime/plum/boost 等总 >200MB)
# 我们对 weasel 的改动放在 upstream/patches/ 单独 commit
upstream/weasel-master/
upstream/*.zip
upstream/*.tar.gz

# Boost build cache (junction)
/bx/

# 临时下载文件 (plum.zip / boost zip 等)
plum.zip
boost*.zip
boost*.tar.gz

# Skill 元数据 (Claude Code 自动生成, 非项目内容)
openspec-apply/
openspec-archive/
openspec-explore/
openspec-proposal/

# 大模型 (522 MB Qwen3-0.6B)
data/models/*.gguf
/ektro-models/

# llama.cpp binaries (15 MB)
tools/llama.cpp/
tools/llama-*.zip

# SQLite amalgamation (8.8 MB sqlite3.c) - 用户按 INSTALL.md 单独下
src-cpp/third_party/sqlite3.c
src-cpp/third_party/sqlite3.h
src-cpp/third_party/sqlite3ext.h
src-cpp/third_party/shell.c

